{
    "name": "utopia-php/avatars",
    "description": "A simple library to fetch human and company avatars from supported providers.",
    "type": "library",
    "keywords": [
        "php",
        "framework",
        "utopia",
        "avatars",
        "gravatar",
        "github"
    ],
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.3",
        "utopia-php/fetch": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.4",
        "laravel/pint": "1.*",
        "phpstan/phpstan": "1.*"
    },
    "scripts": {
        "lint": "./vendor/bin/pint --test --config pint.json",
        "format": "./vendor/bin/pint --config pint.json",
        "check": "./vendor/bin/phpstan analyse --level 8 -c phpstan.neon src tests",
        "test": "./vendor/bin/phpunit --configuration phpunit.xml"
    },
    "autoload": {
        "psr-4": {
            "Utopia\\Avatars\\": "src/Avatars"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Utopia\\Tests\\": "tests/Avatars"
        }
    }
}
